# All variables are OPTIONAL. Without any keys, VoiceGuide runs in Mock Mode.

# Server (apps/server) — API keys live server-side only, never in client code.
# LLM provider: "mock" (default) or "anthropic"
VOICEGUIDE_LLM_PROVIDER=mock
# Only needed when VOICEGUIDE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Anthropic model id used when the anthropic provider is enabled
VOICEGUIDE_ANTHROPIC_MODEL=claude-sonnet-5
# Server port
VOICEGUIDE_SERVER_PORT=8787
# Bind to localhost by default so the LLM proxy is not exposed on the LAN
VOICEGUIDE_SERVER_HOST=127.0.0.1
# Comma-separated browser origins allowed to call the local API server
VOICEGUIDE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Max JSON body accepted by /api/llm, in bytes
VOICEGUIDE_MAX_BODY_BYTES=65536
